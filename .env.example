# Database
DB_NAME=hackathon
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# Backend
DEBUG=false
OCR_LANGUAGE=pol+eng
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384
RERANKER_MODEL=sdadas/polish-reranker-roberta-v3
RERANKER_ENABLED=true
RERANKER_CANDIDATE_MULTIPLIER=4
VISION_LLM_BASE_URL=
VISION_LLM_API_KEY=
VISION_LLM_MODEL=gpt-4o-mini
JWT_SECRET=change-me-in-production

# OpenRouter (priority 1) — set key to use OpenRouter instead of mock
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SEND_APP_HEADERS=true

# Teammates' custom model service (priority 2) — leave empty to use mock
MODEL_SERVICE_URL=
MODEL_SERVICE_API_KEY=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=urbanlab

# JupyterLab
JUPYTER_TOKEN=hackathon

# Frontend (consumed at build/dev time by Vite)
VITE_API_URL=http://localhost:8000
