# Database
DB_NAME=hackathon
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# Backend
DEBUG=false
OCR_LANGUAGE=pol+eng
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384
RERANKER_MODEL=sdadas/polish-reranker-roberta-v3
RERANKER_ENABLED=true
RERANKER_CANDIDATE_MULTIPLIER=4
VISION_LLM_BASE_URL=
VISION_LLM_API_KEY=
VISION_LLM_MODEL=gpt-4o-mini

# Model service — leave empty to use the built-in mock (Polish demo replies)
MODEL_SERVICE_URL=
MODEL_SERVICE_API_KEY=

# JupyterLab
JUPYTER_TOKEN=hackathon

# Frontend (consumed at build/dev time by Vite)
VITE_API_URL=http://localhost:8000
