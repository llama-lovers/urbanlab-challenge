# Database
DB_NAME=hackathon
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# Backend
DEBUG=false
OCR_LANGUAGE=pol+eng
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384
EMBEDDING_SERVICE_URL=http://embedding-minilm:8080
RERANKER_MODEL=sdadas/polish-reranker-roberta-v3
RERANKER_ENABLED=true
RERANKER_CANDIDATE_MULTIPLIER=4
RERANKER_SERVICE_URL=http://reranker-polish-roberta:8080
VISION_LLM_PROVIDER=ollama
VISION_LLM_BASE_URL=http://ollama-glm-ocr:11434
VISION_LLM_API_KEY=
VISION_LLM_MODEL=glm-ocr
OPENAI_API_KEY=
JWT_SECRET=change-me-in-production

# OpenRouter (priority 1) — set key to use OpenRouter instead of mock
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SEND_APP_HEADERS=true

# Teammates' custom model service (priority 2) — leave empty to use mock
MODEL_SERVICE_URL=
MODEL_SERVICE_API_KEY=

# Local generative chat model
CHAT_LLM_PROVIDER=ollama
CHAT_LLM_BASE_URL=http://ollama-qwen-chat:11434
CHAT_LLM_MODEL=qwen3.5:4b

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=urbanlab

# JupyterLab
JUPYTER_TOKEN=hackathon

# Frontend (consumed at build/dev time by Vite)
VITE_API_URL=http://localhost:8000

# Data parser
PARSER_MAX_PAGES=
PARSER_SLEEP_SECONDS=0.3
PARSER_REQUEST_TIMEOUT=30
PARSER_REPROCESS_ALL_DOCUMENTS=false
PARSER_MAX_DOCUMENTS_TO_PROCESS=
PARSER_DOWNLOAD_DIR=/data/bip_downloaded_documents
PARSER_OCR_ZOOM=2.0
PARSER_TESSERACT_PATH=/usr/bin/tesseract
PARSER_BASE_URL=https://bip.lublin.eu